# Network Incident Investigator - Environment Configuration
# Copy this file to .env and fill in your settings

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
DEBUG=false
LOG_LEVEL=INFO

# ============================================================================
# BACKEND API SETTINGS
# ============================================================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=4

# ============================================================================
# DATA SETTINGS
# ============================================================================
DATA_DIR=./data
EXPORTS_DIR=./exports

# ============================================================================
# ANOMALY DETECTION SETTINGS
# ============================================================================
DEFAULT_DETECTION_METHOD=zscore  # zscore, mad, isolation_forest, stl
DEFAULT_ANOMALY_THRESHOLD=3.0
DEFAULT_WINDOW_SIZE=30

# ============================================================================
# GENAI PROVIDER SELECTION
# ============================================================================
# Options: ollama_local, openai, vertex_ai, azure_openai
GENAI_PROVIDER=ollama_local

# ============================================================================
# OLLAMA (LOCAL) CONFIGURATION
# ============================================================================
# Use this if GENAI_PROVIDER=ollama_local
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2  # llama2, mistral, neural-chat, etc.

# ============================================================================
# OPENAI CONFIGURATION
# ============================================================================
# Use this if GENAI_PROVIDER=openai
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo  # gpt-3.5-turbo, gpt-4, etc.

# ============================================================================
# VERTEX AI (GOOGLE CLOUD) CONFIGURATION
# ============================================================================
# Use this if GENAI_PROVIDER=vertex_ai
# Requires Google Cloud SDK and authentication
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
VERTEX_MODEL=text-bison@001

# ============================================================================
# AZURE OPENAI CONFIGURATION
# ============================================================================
# Use this if GENAI_PROVIDER=azure_openai
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=

# ============================================================================
# GENAI COMMON SETTINGS
# ============================================================================
GENAI_TEMPERATURE=0.7  # 0.0 = deterministic, 1.0 = creative
GENAI_MAX_TOKENS=1000
